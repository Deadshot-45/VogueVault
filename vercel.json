{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://vault-vogue-expressjs.vercel.app/api/:path*"
    },
    {
      "source": "/images/:path*",
      "destination": "https://vault-vogue-expressjs.vercel.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
